<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ════════════════════════════════════════════════════════════════════════════
  TestNG Suite Configuration — Restful Booker API Automation Framework
  ════════════════════════════════════════════════════════════════════════════

  Suite Structure:
    ├── Smoke Tests     — Fast sanity checks (TC_CREATE_001, TC_GET_001, TC_E2E_001)
    ├── Regression      — Full regression including negative tests
    └── E2E             — End-to-end flow validation

  Execution:
    mvn test                          → Runs this suite
    mvn test -Dgroups=smoke           → Runs only smoke tests
    mvn test -Dgroups=e2e             → Runs only E2E tests
    mvn allure:report                 → Generates Allure HTML report
    open test-output/ExtentReport.html → View ExtentReports dashboard
-->
<suite name="Restful Booker API — Full Automation Suite"
       verbose="2"
       parallel="classes"
       thread-count="3"
       data-provider-thread-count="3">

    <!-- ── Suite-level listeners ─────────────────────────────────────────── -->
    <!--
      Note: ExtentReportListener is registered via @Listeners on BaseTest.
      Allure listener is registered automatically via allure-testng dependency.
      No explicit listener declarations needed here.
    -->

    <!-- ══════════════════════════════════════════════════════════════════════
         CREATE BOOKING — POST /booking Test Group
    ══════════════════════════════════════════════════════════════════════ -->
    <test name="Create Booking API Tests" preserve-order="true">
        <classes>
            <class name="com.booker.tests.CreateBookingTest">
                <methods>
                    <!-- Positive test cases first, then negative -->
                    <include name="tc_create_001_validPayload_returns200WithBookingId"/>
                    <include name="tc_create_002_validPayload_responseBodyMatchesRequest"/>
                    <include name="tc_create_003_emptyBody_returnsError"/>
                    <include name="tc_create_004_missingFirstname_returnsError"/>
                    <include name="tc_create_005_invalidContentType_returnsError"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════════════
         GET BOOKING — GET /booking/{bookingId} Test Group
    ══════════════════════════════════════════════════════════════════════ -->
    <test name="Get Booking API Tests" preserve-order="true">
        <classes>
            <class name="com.booker.tests.GetBookingTest">
                <methods>
                    <!-- Positive test cases first, then negative -->
                    <include name="tc_get_001_validBookingId_returns200"/>
                    <include name="tc_get_002_validBookingId_responseMatchesOriginalData"/>
                    <include name="tc_get_003_nonExistentBookingId_returns404"/>
                    <include name="tc_get_004_boundaryBookingId_returns404"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════════════
         END-TO-END FLOW — Full Create → Get → Validate Journey
    ══════════════════════════════════════════════════════════════════════ -->
    <test name="End-to-End Booking Flow Tests" preserve-order="true">
        <classes>
            <class name="com.booker.tests.E2EBookingFlowTest">
                <methods>
                    <include name="tc_e2e_001_createAndRetrieveBooking_fullFlowValidation"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
